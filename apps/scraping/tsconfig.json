{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pymeTracker/db/*": ["../../shared/db/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
