{
  "name": "pymetracker",
  "version": "1.0.0",
  "description": "PymeTracker monorepo — web app + scraping service",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "shared/*"
  ],
  "scripts": {
    "dev:web": "NEXT_IGNORE_INCORRECT_LOCKFILE=1 npm run dev --workspace=apps/web",
    "scraper:pipeline": "npm run run:pipeline --workspace=apps/scraping",
    "build:web": "npm run build --workspace=apps/web",
    "db:local": "docker compose -f shared/db/docker-compose.yml up -d",
    "db:seed": "npm run db:seed --workspace=shared/db",
    "db:open": "npm run db:open --workspace=shared/db",
    "db:local:down": "docker compose -f shared/db/docker-compose.yml down -v",
    "db:generate": "npm run generate --workspace=shared/db",
    "db:migrate": "npm run migrate --workspace=shared/db",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TioSaturno/PymeTracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TioSaturno/PymeTracker/issues"
  },
  "homepage": "https://github.com/TioSaturno/PymeTracker#readme"
}
