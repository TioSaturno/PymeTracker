{
  "name": "pymetracker",
  "version": "1.0.0",
  "description": "PymeTracker monorepo — web app + scraping service",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "db:local": "docker compose -f shared/db/docker-compose.yml up -d",
    "db:local:down": "docker compose -f shared/db/docker-compose.yml down",
    "db:generate": "npm run generate --workspace=shared/db",
    "db:migrate": "npm run migrate --workspace=shared/db",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TioSaturno/PymeTracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TioSaturno/PymeTracker/issues"
  },
  "homepage": "https://github.com/TioSaturno/PymeTracker#readme",
  "dependencies": {
    "@esbuild/darwin-x64": "^0.28.0",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10"
  }
}
